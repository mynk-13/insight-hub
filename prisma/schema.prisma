generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum Tier {
  FREE
  PRO
}

enum SourceType {
  PDF
  DOCX
  URL
  MARKDOWN
}

enum SourceStatus {
  PENDING
  EXTRACTING
  OCR_RUNNING
  CHUNKING
  EMBEDDING
  INDEXED
  FAILED
}

enum ContextType {
  WORKSPACE
  COLLECTION
  SOURCE
}

enum MessageRole {
  USER
  ASSISTANT
}

enum AnnotationType {
  HIGHLIGHT
  COMMENT
}

enum GatewayType {
  STRIPE
  RAZORPAY
  PAYPAL
  BILLDESK
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
  EXPIRED
}

enum AuditAction {
  SIGN_IN
  SIGN_OUT
  SIGN_IN_FAILED
  MAGIC_LINK_REQUESTED
  WORKSPACE_CREATED
  WORKSPACE_UPDATED
  WORKSPACE_DELETED
  MEMBER_INVITED
  MEMBER_JOINED
  MEMBER_REMOVED
  ROLE_CHANGED
  OWNERSHIP_TRANSFERRED
  SOURCE_UPLOADED
  SOURCE_DELETED
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_CANCELED
}

// ─── Auth.js Required Models ──────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  members         Member[]
  chats           Chat[]
  annotations     Annotation[]
  auditLogs       AuditLog[]
  sentInvitations Invitation[] @relation("InvitedBy")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Domain Tables (14) ───────────────────────────────────────────────────────

model Workspace {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  avatarUrl   String?
  ownerId     String
  tier        Tier      @default(FREE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  members       Member[]
  sources       Source[]
  chats         Chat[]
  collections   Collection[]
  invitations   Invitation[]
  subscriptions Subscription[]
  auditLogs     AuditLog[]

  @@map("workspaces")
}

model Member {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        Role     @default(VIEWER)
  joinedAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("members")
}

model Source {
  id          String       @id @default(cuid())
  workspaceId String
  title       String
  type        SourceType
  url         String?
  blobKey     String?
  mimeType    String?
  sizeBytes   Int?
  contentHash String?
  status      SourceStatus @default(PENDING)
  pageCount   Int?
  wordCount   Int?
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  // Populated by Postgres trigger; GIN index applied in custom migration
  searchVector Unsupported("tsvector")?

  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chunks      Chunk[]
  collections SourceCollection[]
  annotations Annotation[]

  @@unique([workspaceId, contentHash])
  @@index([workspaceId])
  @@index([status])
  @@map("sources")
}

model Chunk {
  id          String   @id @default(cuid())
  sourceId    String
  workspaceId String
  content     String   @db.Text
  contentHash String
  tokenCount  Int
  chunkIndex  Int
  pageNumber  Int?
  metadata    Json     @default("{}")
  pineconeId  String?
  createdAt   DateTime @default(now())

  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([workspaceId])
  @@map("chunks")
}

model Chat {
  id          String      @id @default(cuid())
  workspaceId String
  userId      String
  title       String?
  contextType ContextType @default(WORKSPACE)
  contextId   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([workspaceId])
  @@index([userId])
  @@map("chats")
}

model Message {
  id           String      @id @default(cuid())
  chatId       String
  workspaceId  String
  role         MessageRole
  content      String      @db.Text
  citations    Json        @default("[]")
  model        String?
  tokensIn     Int?
  tokensOut    Int?
  costUsd      Decimal?    @db.Decimal(10, 6)
  retrievalMs  Int?
  generationMs Int?
  createdAt    DateTime    @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@map("messages")
}

model Collection {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  description String?
  isPinned    Boolean   @default(false)
  sortOrder   Int       @default(0)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sources   SourceCollection[]

  @@index([workspaceId])
  @@map("collections")
}

model SourceCollection {
  sourceId     String
  collectionId String
  addedAt      DateTime @default(now())

  source     Source     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([sourceId, collectionId])
  @@map("source_collections")
}

model Annotation {
  id          String         @id @default(cuid())
  workspaceId String
  sourceId    String
  userId      String
  type        AnnotationType @default(HIGHLIGHT)
  color       String?
  content     String?        @db.Text
  anchorText  String         @db.Text
  anchorStart Int
  anchorEnd   Int
  pageNumber  Int?
  isResolved  Boolean        @default(false)
  parentId    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  source  Source       @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Annotation?  @relation("Replies", fields: [parentId], references: [id])
  replies Annotation[] @relation("Replies")

  @@index([sourceId])
  @@index([userId])
  @@map("annotations")
}

model Subscription {
  id                 String             @id @default(cuid())
  workspaceId        String             @unique
  tier               Tier
  gateway            GatewayType
  gatewaySubId       String?
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  paymentEvents PaymentEvent[]

  @@map("subscriptions")
}

model PaymentEvent {
  id             String      @id @default(cuid())
  subscriptionId String
  workspaceId    String
  gateway        GatewayType
  eventType      String
  gatewayEventId String
  payload        Json
  processedAt    DateTime    @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  // Idempotency: each gateway event is processed exactly once
  @@unique([gateway, gatewayEventId])
  @@map("payment_events")
}

model Invitation {
  id          String           @id @default(cuid())
  workspaceId String
  email       String
  role        Role             @default(VIEWER)
  token       String           @unique @default(cuid())
  status      InvitationStatus @default(PENDING)
  invitedById String
  expiresAt   DateTime
  respondedAt DateTime?
  createdAt   DateTime         @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([email])
  @@map("invitations")
}

model AuditLog {
  id          String      @id @default(cuid())
  workspaceId String?
  userId      String?
  action      AuditAction
  metadata    Json        @default("{}")
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([userId])
  @@map("audit_logs")
}
