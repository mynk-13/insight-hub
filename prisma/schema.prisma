// Prisma schema — tables defined in Phase 2 once REQ-01 (Neon) credentials are provided
// Connection configured for Neon Postgres 16 (Mumbai region) with PgBouncer pooling

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}
